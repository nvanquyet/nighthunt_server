# ══════════════════════════════════════════════════════════════
# NightHunt Environment Template
# Copy sang .env.local (dev) hoặc .env.production (production)
# ══════════════════════════════════════════════════════════════

# Bắt buộc: khai báo file này để docker-compose biết load env_file đúng
ENV_FILE=.env.local

# ── Database ───────────────────────────────────────────────────
MYSQL_DATABASE=nighthunt
MYSQL_USER=nighthunt
MYSQL_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
DB_URL=jdbc:mysql://mysql:3306/nighthunt
DB_USERNAME=nighthunt
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis ──────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── Realtime Gateway / NATS ───────────────────────────────────
REALTIME_NATS_ENABLED=true
NATS_URL=nats://nats:4222
NATS_SUBJECT_PREFIX=rt.gateway
JETSTREAM_OUTBOX_ENABLED=true
JETSTREAM_STREAM_NAME=NIGHTHUNT_EVENTS
JETSTREAM_SUBJECTS=events.>
JETSTREAM_OUTBOX_BATCH_SIZE=100
JETSTREAM_OUTBOX_POLL_DELAY_MILLIS=500
GATEWAY_ID=gateway-1
GATEWAY_PORT=8090
GATEWAY_METRICS_PORT=9091
GATEWAY_REDIS_URI=
WS_PATH=/api/ws/game
WS_TICKET_TTL_SECONDS=45
WS_ACCEPT_BACKLOG=8192
WS_MAX_FRAME_BYTES=4096
WS_MAX_PENDING_OUTBOUND_BYTES=262144
WS_HEARTBEAT_TIMEOUT_SECONDS=45
WS_PRESENCE_LEASE_SECONDS=60

# ── SSL / HTTPS ────────────────────────────────────────────────
# LOCAL DEV:   SSL_ENABLED=true  (Spring Boot tự handle SSL với mkcert cert)
# PRODUCTION:  SSL_ENABLED=false (Nginx handle SSL, Spring Boot chạy HTTP)
SSL_ENABLED=true
SERVER_PORT=8443
SSL_KEYSTORE=/app/certs/keystore.p12
SSL_KEYSTORE_PASSWORD=changeit
SSL_KEYSTORE_TYPE=PKCS12
SSL_KEY_ALIAS=nighthunt
USE_HTTPS=true
API_BASE_URL=https://localhost:8443

# ── JWT & Security ─────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_SECRET_KEY_HERE_!!
CSRF_ENABLED=false

# ── CORS ───────────────────────────────────────────────────────
# LOCAL: https://localhost:8443
# PRODUCTION: https://api.nighthunt.com
CORS_ALLOWED_ORIGINS=https://localhost:8443

# ── Dedicated Server ───────────────────────────────────────────
VPS_PUBLIC_IP=127.0.0.1
DS_IMAGE_REF=ghcr.io/yourname/nighthunt-ds:latest
ADMIN_SECRET=CHANGE_ME_DS_ADMIN_SECRET
DS_BACKEND_INTERNAL_URL=http://nighthunt-backend:8080
DS_PORT_START=9000
DS_PORT_END=9100

# GHCR credentials — backend cần để docker pull DS image (private registry)
# Tạo PAT tại: https://github.com/settings/tokens → Classic → scope: read:packages
GHCR_OWNER=your-github-username
GHCR_TOKEN=CHANGE_ME_GITHUB_PAT_READ_PACKAGES
DS_MAX_PLAYERS=16
DS_DOCKER_ENABLED=false

# ── Dashboard ──────────────────────────────────────────────────
DASHBOARD_PORT=3001
# LOCAL DEV:   backend uses SSL (Spring Boot self-signed / mkcert)
# PRODUCTION:  backend runs plain HTTP — nginx terminates TLS externally
#   Dev:        DASHBOARD_BACKEND_URL=https://nighthunt-backend:8443
#   Production: DASHBOARD_BACKEND_URL=http://nighthunt-backend:8080
DASHBOARD_BACKEND_URL=https://nighthunt-backend:8443
DASHBOARD_ADMIN_USER=admin
DASHBOARD_ADMIN_PASS=CHANGE_ME_ADMIN_PASSWORD
DASHBOARD_ROOT_USER=root
DASHBOARD_ROOT_PASS=CHANGE_ME_ROOT_PASSWORD

# Custom Game / Relay
# ──────────────────────────────────────────────────────────────────────────────
# RECOMMENDED: Mode A — Full relay server (works on mobile, different WiFi, no port-forward)
#   1. Set RELAY_HOST to your VPS public IP (same as VPS_PUBLIC_IP usually)
#   2. Set RELAY_SERVER_URL to the internal address of the relay container
#   3. Open UDP ports 7777-7900 in your VPS firewall
#
# Fallback: Mode C — Direct P2P (LAN or port-forward)
#   Leave RELAY_SERVER_URL blank; host's detected IP is sent to clients.
#   Works on LAN automatically; internet requires host to open RELAY_PORT.
RELAY_SERVER_URL=http://nighthunt-relay:7776   # internal HTTP API of relay_server.py
RELAY_HOST=                                    # VPS public IP (sent to game clients as relay address)
RELAY_PORT=7777                                # UDP port (Mode C only; Mode A uses dynamic ports)
RELAY_SESSION_TTL_HOURS=2
RELAY_PORT_START=7777                          # UDP port pool start (Mode A)
RELAY_PORT_END=7900                            # UDP port pool end (Mode A) — supports 124 concurrent games
