# ══════════════════════════════════════════════════════════════
# NightHunt Environment Template
# Copy sang .env.local (dev) hoặc .env.production (production)
# ══════════════════════════════════════════════════════════════

# Bắt buộc: khai báo file này để docker-compose biết load env_file đúng
ENV_FILE=.env.local

# ── Database ───────────────────────────────────────────────────
MYSQL_DATABASE=nighthunt
MYSQL_USER=nighthunt
MYSQL_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
DB_URL=jdbc:mysql://mysql:3306/nighthunt
DB_USERNAME=nighthunt
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis ──────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── SSL / HTTPS ────────────────────────────────────────────────
# LOCAL DEV:   SSL_ENABLED=true  (Spring Boot tự handle SSL với mkcert cert)
# PRODUCTION:  SSL_ENABLED=false (Nginx handle SSL, Spring Boot chạy HTTP)
SSL_ENABLED=true
SERVER_PORT=8443
SSL_KEYSTORE=/app/certs/keystore.p12
SSL_KEYSTORE_PASSWORD=changeit
SSL_KEYSTORE_TYPE=PKCS12
SSL_KEY_ALIAS=nighthunt
USE_HTTPS=true
API_BASE_URL=https://localhost:8443

# ── JWT & Security ─────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_SECRET_KEY_HERE_!!
CSRF_ENABLED=false

# ── CORS ───────────────────────────────────────────────────────
# LOCAL: https://localhost:8443
# PRODUCTION: https://api.nighthunt.com
CORS_ALLOWED_ORIGINS=https://localhost:8443

# ── Dedicated Server ───────────────────────────────────────────
VPS_PUBLIC_IP=127.0.0.1
DS_IMAGE_REF=ghcr.io/yourname/nighthunt-ds:latest
DS_ADMIN_SECRET=CHANGE_ME_DS_ADMIN_SECRET
DS_BACKEND_INTERNAL_URL=https://nighthunt-backend:8443
DS_PORT_START=7777
DS_PORT_END=7900

# GHCR credentials — backend cần để docker pull DS image (private registry)
# Tạo PAT tại: https://github.com/settings/tokens → Classic → scope: read:packages
GHCR_OWNER=your-github-username
GHCR_TOKEN=CHANGE_ME_GITHUB_PAT_READ_PACKAGES
DS_MAX_PLAYERS=16
DS_DOCKER_ENABLED=false

# ── Dashboard ──────────────────────────────────────────────────
DASHBOARD_PORT=3001
DASHBOARD_BACKEND_URL=https://nighthunt-backend:8443
DASHBOARD_ADMIN_USER=admin
DASHBOARD_ADMIN_PASS=CHANGE_ME_ADMIN_PASSWORD
DASHBOARD_ROOT_USER=root
DASHBOARD_ROOT_PASS=CHANGE_ME_ROOT_PASSWORD
